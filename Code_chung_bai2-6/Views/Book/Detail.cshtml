@model Book
@{
    ViewData["Title"] = "Chi tiết sách";
}

<h2 class="mb-4">Chi tiết sách</h2>

<table class="table table-bordered">
    <tr>
        <th>Id</th>
        <td>@Model.Id</td>
    </tr>
    <tr>
        <th>Name</th>
        <td>@Model.Name</td>
    </tr>
    <tr>
        <th>Price</th>
        <td>@Model.Price</td>
    </tr>
</table>

<a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
